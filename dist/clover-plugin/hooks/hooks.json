{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/setup.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_DATA}/bin/clover-hook review-plan",
            "timeout": 300
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -c '. \"${CLAUDE_PLUGIN_DATA}/env.sh\" 2>/dev/null; exec \"${CLAUDE_PLUGIN_DATA}/bin/clover-hook\" log-prompt'"
          }
        ]
      }
    ]
  }
}
